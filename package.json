{
  "name": "e-commerce-playwright",
  "version": "1.0.0",
  "description": "E-commerce Website Testing with Playwright and TypeScript",
  "main": "index.js",
  "scripts": {
    "tests:gui": "npx playwright test",
    "tests:gui:headed": "npx playwright test --headed",
    "show-report": "npx playwright show-report",
    "lint": "npx eslint . --max-warnings=0",
    "only-changed": "npx playwright test --only-changed",
    "ui-mode": "npx playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "jiti": "^2.6.1",
    "prettier": "^3.7.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
