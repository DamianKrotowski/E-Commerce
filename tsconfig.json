{
  "compilerOptions": {
    "noImplicitAny": true,
    "target": "ESNext",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strictNullChecks": false,
    "esModuleInterop": true,
    "types": ["node"],
    "baseUrl": "./",
    "paths": {
      "@_pages/*": ["src/pages/*"],
      "@_testdata/*": ["src/testdata/*"],
      "@_tests/*": ["src/tests/*"],
      "@_fixtures/*": ["src/fixtures/*"],
      "@_components/*": ["src/components/*"]
    }
  }
}
